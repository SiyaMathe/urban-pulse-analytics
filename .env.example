# ============================================================
# Urban Pulse Analytics — Local Development Environment
# Copy this to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Local SQL Server (Docker) ────────────────────────────────
AZURE_SQL_CONNECTION_STRING="Server=localhost,1433;Database=UrbanPulseAnalytics;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True;"

# ── Local Azurite Storage Emulator ───────────────────────────
AZURE_STORAGE_CONNECTION_STRING="UseDevelopmentStorage=true"

# ── Azure (Production / Staging) — fill from Azure Portal ────
# AZURE_SQL_CONNECTION_STRING="Server=<server>.database.windows.net;Database=UrbanPulseAnalytics;User Id=sqladmin;Password=<password>;Encrypt=True;"
# AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net"

# ── Application Insights ─────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=<key>;IngestionEndpoint=https://southafricanorth-0.in.applicationinsights.azure.com/"

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_BASE_URL="http://localhost:7071/api"
VITE_ENVIRONMENT="development"

# ── Function App local settings ──────────────────────────────
FUNCTIONS_WORKER_RUNTIME="dotnet-isolated"
AzureWebJobsStorage="UseDevelopmentStorage=true"
